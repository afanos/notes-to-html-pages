{
	"name": "notes-to-html-pages",
	"version": "0.6.0",
	"description": "Export Markdown notes into clean, readable HTML pages with table of contents and in-app reading.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
	},
	"keywords": [
		"obsidian",
		"markdown",
		"html",
		"export"
	],
	"license": "MIT",
	"dependencies": {
		"markdown-it": "^14.1.0"
	},
	"devDependencies": {
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^22.10.2",
		"esbuild": "^0.25.0",
		"obsidian": "latest",
		"typescript": "^5.8.0"
	}
}
